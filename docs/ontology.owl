        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Name of the device.</rdfs:comment>
        <rdfs:label xml:lang="en">device name</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.uoc.edu/knowledgeManagement/medicalDevicesOntology#eudamedIncidentRef -->


    <owl:DatatypeProperty rdf:about="http://www.uoc.edu/knowledgeManagement/medicalDevicesOntology#eudamedIncidentRef">
