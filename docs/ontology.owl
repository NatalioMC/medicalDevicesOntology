        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Country where the incident was reported.</rdfs:comment>
        <rdfs:label xml:lang="en">country reported</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.uoc.edu/knowledgeManagement/medicalDevicesOntology#description -->


    <owl:DatatypeProperty rdf:about="http://www.uoc.edu/knowledgeManagement/medicalDevicesOntology#description">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Textual description of a resource.</rdfs:comment>
        <rdfs:label xml:lang="en">description</rdfs:label>
    </owl:DatatypeProperty>
    


