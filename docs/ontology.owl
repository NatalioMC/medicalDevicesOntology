<?xml version="1.0"?>
<rdf:RDF xmlns="http://www.uoc.edu/knowledgeManagement/medicalDevicesOntology#"
     xml:base="http://www.uoc.edu/knowledgeManagement/medicalDevicesOntology"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:swrl="http://www.w3.org/2003/11/swrl#"
     xmlns:swrla="http://swrl.stanford.edu/ontologies/3.3/swrla.owl#"
     xmlns:swrlb="http://www.w3.org/2003/11/swrlb#"
     xmlns:medicalDevicesOntology="http://www.uoc.edu/knowledgeManagement/medicalDevicesOntology#">
    <owl:Ontology rdf:about="http://www.uoc.edu/knowledgeManagement/medicalDevicesOntology">
        <rdfs:comment xml:lang="en">Ontology for representing medical devices, manufacturers, risks, incidents and corrective actions.</rdfs:comment>
        <rdfs:label xml:lang="en">Medical Devices Ontology</rdfs:label>
    </owl:Ontology>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Annotation properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://swrl.stanford.edu/ontologies/3.3/swrla.owl#isRuleEnabled -->


    <owl:AnnotationProperty rdf:about="http://swrl.stanford.edu/ontologies/3.3/swrla.owl#isRuleEnabled"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Datatypes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://www.w3.org/2001/XMLSchema#date -->


    <rdfs:Datatype rdf:about="http://www.w3.org/2001/XMLSchema#date"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://www.uoc.edu/knowledgeManagement/medicalDevicesOntology#hasActionType -->


    <owl:ObjectProperty rdf:about="http://www.uoc.edu/knowledgeManagement/medicalDevicesOntology#hasActionType">
        <rdfs:domain rdf:resource="http://www.uoc.edu/knowledgeManagement/medicalDevicesOntology#CorrectiveAction"/>
        <rdfs:domain>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.uoc.edu/knowledgeManagement/medicalDevicesOntology#hasActionType"/>
                <owl:allValuesFrom rdf:resource="http://www.uoc.edu/knowledgeManagement/medicalDevicesOntology#FSCA"/>
            </owl:Restriction>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.uoc.edu/knowledgeManagement/medicalDevicesOntology#FSCA"/>
        <rdfs:comment xml:lang="en">Relates a corrective action to its FSCA type.</rdfs:comment>
        <rdfs:label xml:lang="en">has action type</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.uoc.edu/knowledgeManagement/medicalDevicesOntology#hasAffectedDeviceType -->


    <owl:ObjectProperty rdf:about="http://www.uoc.edu/knowledgeManagement/medicalDevicesOntology#hasAffectedDeviceType">
        <rdfs:domain rdf:resource="http://www.uoc.edu/knowledgeManagement/medicalDevicesOntology#Risk"/>
        <rdfs:range rdf:resource="http://www.uoc.edu/knowledgeManagement/medicalDevicesOntology#AffectedDeviceType"/>
        <rdfs:comment xml:lang="en">Relates a risk to the affected device type.</rdfs:comment>
        <rdfs:label xml:lang="en">has affected device type</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.uoc.edu/knowledgeManagement/medicalDevicesOntology#hasCorrectiveAction -->


    <owl:ObjectProperty rdf:about="http://www.uoc.edu/knowledgeManagement/medicalDevicesOntology#hasCorrectiveAction">
        <rdfs:domain rdf:resource="http://www.uoc.edu/knowledgeManagement/medicalDevicesOntology#Incident"/>
        <rdfs:domain>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.uoc.edu/knowledgeManagement/medicalDevicesOntology#involvesDevice"/>
                <owl:someValuesFrom rdf:resource="http://www.uoc.edu/knowledgeManagement/medicalDevicesOntology#Device"/>
            </owl:Restriction>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.uoc.edu/knowledgeManagement/medicalDevicesOntology#CorrectiveAction"/>
        <rdfs:range>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.uoc.edu/knowledgeManagement/medicalDevicesOntology#hasActionType"/>
                <owl:allValuesFrom rdf:resource="http://www.uoc.edu/knowledgeManagement/medicalDevicesOntology#FSCA"/>
            </owl:Restriction>
        </rdfs:range>
        <rdfs:comment xml:lang="en">Relates an incident to a corrective action.</rdfs:comment>
        <rdfs:label xml:lang="en">has corrective action</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.uoc.edu/knowledgeManagement/medicalDevicesOntology#hasManufacturer -->


    <owl:ObjectProperty rdf:about="http://www.uoc.edu/knowledgeManagement/medicalDevicesOntology#hasManufacturer">
        <rdfs:domain rdf:resource="http://www.uoc.edu/knowledgeManagement/medicalDevicesOntology#Device"/>
        <rdfs:domain>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.uoc.edu/knowledgeManagement/medicalDevicesOntology#hasManufacturer"/>
                <owl:someValuesFrom rdf:resource="http://www.uoc.edu/knowledgeManagement/medicalDevicesOntology#Manufacturer"/>
            </owl:Restriction>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.uoc.edu/knowledgeManagement/medicalDevicesOntology#Manufacturer"/>
        <rdfs:range rdf:resource="http://xmlns.com/foaf/0.1/Organization"/>
        <rdfs:comment xml:lang="en">Relates a device to its manufacturer.</rdfs:comment>
        <rdfs:label xml:lang="en">has manufacturer</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.uoc.edu/knowledgeManagement/medicalDevicesOntology#hasRisk -->


    <owl:ObjectProperty rdf:about="http://www.uoc.edu/knowledgeManagement/medicalDevicesOntology#hasRisk">
        <rdfs:domain rdf:resource="http://www.uoc.edu/knowledgeManagement/medicalDevicesOntology#Device"/>
        <rdfs:domain>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.uoc.edu/knowledgeManagement/medicalDevicesOntology#hasManufacturer"/>
                <owl:someValuesFrom rdf:resource="http://www.uoc.edu/knowledgeManagement/medicalDevicesOntology#Manufacturer"/>
            </owl:Restriction>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.uoc.edu/knowledgeManagement/medicalDevicesOntology#Risk"/>
        <rdfs:comment xml:lang="en">Relates a device to an identified risk.</rdfs:comment>
        <rdfs:label xml:lang="en">has risk</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.uoc.edu/knowledgeManagement/medicalDevicesOntology#hasRiskClass -->


    <owl:ObjectProperty rdf:about="http://www.uoc.edu/knowledgeManagement/medicalDevicesOntology#hasRiskClass">
        <rdfs:domain rdf:resource="http://www.uoc.edu/knowledgeManagement/medicalDevicesOntology#Device"/>
        <rdfs:domain>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.uoc.edu/knowledgeManagement/medicalDevicesOntology#hasManufacturer"/>
                <owl:someValuesFrom rdf:resource="http://www.uoc.edu/knowledgeManagement/medicalDevicesOntology#Manufacturer"/>
            </owl:Restriction>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.uoc.edu/knowledgeManagement/medicalDevicesOntology#RiskClass"/>
        <rdfs:comment xml:lang="en">Relates a device to its regulatory risk class.</rdfs:comment>
        <rdfs:label xml:lang="en">has risk class</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.uoc.edu/knowledgeManagement/medicalDevicesOntology#involvesDevice -->


    <owl:ObjectProperty rdf:about="http://www.uoc.edu/knowledgeManagement/medicalDevicesOntology#involvesDevice">
        <rdfs:domain rdf:resource="http://www.uoc.edu/knowledgeManagement/medicalDevicesOntology#Incident"/>
        <rdfs:domain>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.uoc.edu/knowledgeManagement/medicalDevicesOntology#involvesDevice"/>
                <owl:someValuesFrom rdf:resource="http://www.uoc.edu/knowledgeManagement/medicalDevicesOntology#Device"/>
            </owl:Restriction>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.uoc.edu/knowledgeManagement/medicalDevicesOntology#Device"/>
        <rdfs:range>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.uoc.edu/knowledgeManagement/medicalDevicesOntology#hasManufacturer"/>
                <owl:someValuesFrom rdf:resource="http://www.uoc.edu/knowledgeManagement/medicalDevicesOntology#Manufacturer"/>
            </owl:Restriction>
        </rdfs:range>
        <rdfs:comment xml:lang="en">Relates an incident to the involved device.</rdfs:comment>
        <rdfs:label xml:lang="en">involves device</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.uoc.edu/knowledgeManagement/medicalDevicesOntology#relatedToRisk -->


    <owl:ObjectProperty rdf:about="http://www.uoc.edu/knowledgeManagement/medicalDevicesOntology#relatedToRisk">
        <rdfs:domain rdf:resource="http://www.uoc.edu/knowledgeManagement/medicalDevicesOntology#Incident"/>
        <rdfs:domain>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.uoc.edu/knowledgeManagement/medicalDevicesOntology#involvesDevice"/>
                <owl:someValuesFrom rdf:resource="http://www.uoc.edu/knowledgeManagement/medicalDevicesOntology#Device"/>
            </owl:Restriction>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.uoc.edu/knowledgeManagement/medicalDevicesOntology#Risk"/>
        <rdfs:comment xml:lang="en">Relates an incident to the associated risk.</rdfs:comment>
        <rdfs:label xml:lang="en">related to risk</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Data properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://www.uoc.edu/knowledgeManagement/medicalDevicesOntology#actionDate -->


    <owl:DatatypeProperty rdf:about="http://www.uoc.edu/knowledgeManagement/medicalDevicesOntology#actionDate">
        <rdfs:domain rdf:resource="http://www.uoc.edu/knowledgeManagement/medicalDevicesOntology#CorrectiveAction"/>
        <rdfs:domain>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.uoc.edu/knowledgeManagement/medicalDevicesOntology#hasActionType"/>
