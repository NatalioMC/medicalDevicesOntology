    </owl:DatatypeProperty>
    


    <!-- http://www.uoc.edu/knowledgeManagement/medicalDevicesOntology#deviceName -->


    <owl:DatatypeProperty rdf:about="http://www.uoc.edu/knowledgeManagement/medicalDevicesOntology#deviceName">
        <rdfs:domain rdf:resource="http://www.uoc.edu/knowledgeManagement/medicalDevicesOntology#Device"/>
