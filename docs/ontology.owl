            </owl:Restriction>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
        <rdfs:comment xml:lang="en">Date of the corrective action.</rdfs:comment>
        <rdfs:label xml:lang="en">action date</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.uoc.edu/knowledgeManagement/medicalDevicesOntology#authorizationNumber -->


    <owl:DatatypeProperty rdf:about="http://www.uoc.edu/knowledgeManagement/medicalDevicesOntology#authorizationNumber">
        <rdfs:domain rdf:resource="http://www.uoc.edu/knowledgeManagement/medicalDevicesOntology#Manufacturer"/>
        <rdfs:domain rdf:resource="http://xmlns.com/foaf/0.1/Organization"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Authorization number of the manufacturer.</rdfs:comment>
        <rdfs:label xml:lang="en">authorization number</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.uoc.edu/knowledgeManagement/medicalDevicesOntology#contactEmail -->


    <owl:DatatypeProperty rdf:about="http://www.uoc.edu/knowledgeManagement/medicalDevicesOntology#contactEmail">
        <rdfs:domain rdf:resource="http://www.uoc.edu/knowledgeManagement/medicalDevicesOntology#Manufacturer"/>
        <rdfs:domain rdf:resource="http://xmlns.com/foaf/0.1/Organization"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Contact email of the manufacturer.</rdfs:comment>
        <rdfs:label xml:lang="en">contact email</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.uoc.edu/knowledgeManagement/medicalDevicesOntology#country -->


    <owl:DatatypeProperty rdf:about="http://www.uoc.edu/knowledgeManagement/medicalDevicesOntology#country">
        <rdfs:domain rdf:resource="http://www.uoc.edu/knowledgeManagement/medicalDevicesOntology#Manufacturer"/>
        <rdfs:domain rdf:resource="http://xmlns.com/foaf/0.1/Organization"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Country of the manufacturer.</rdfs:comment>
        <rdfs:label xml:lang="en">country</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.uoc.edu/knowledgeManagement/medicalDevicesOntology#countryReported -->


    <owl:DatatypeProperty rdf:about="http://www.uoc.edu/knowledgeManagement/medicalDevicesOntology#countryReported">
        <rdfs:domain rdf:resource="http://www.uoc.edu/knowledgeManagement/medicalDevicesOntology#Incident"/>
        <rdfs:domain>
