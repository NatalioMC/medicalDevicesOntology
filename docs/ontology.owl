            </owl:Restriction>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
        <rdfs:comment xml:lang="en">Date when the incident occurred.</rdfs:comment>
        <rdfs:label xml:lang="en">event date</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.uoc.edu/knowledgeManagement/medicalDevicesOntology#fscaId -->


