          :deviceId "DEV-001" ;
          :deviceName "Pacemaker X" ;
          :intendedPurpose "Cardiac rhythm management" ;
          :isActive "true"^^xsd:boolean ;
          :isIvd "false"^^xsd:boolean ;
          :isReusable "false"^^xsd:boolean ;
          :regulatoryFramework "MDR" ;
          :udiDi "UDI-DEV-001" ;
          rdfs:comment "Example instance of a medical device."@en ;
          rdfs:label "Device 1"@en .


